2025-11-13 11:31:18 Neo4jProductExporter DEBUG: Medication Graph DB Query: MATCH (p:Product)-[:CONTAINS]->(d:Drug) WHERE p.mmiId IN $ids CALL {    WITH d    OPTIONAL MATCH (d)-[:HAS_DOSE_FORM]->(df:MmiDoseForm)     OPTIONAL MATCH (df)-[:CORRESPONDS_TO]->(de:EDQM)-[:BELONGS_TO]->(dfcs:CodingSystem)     RETURN df, CASE WHEN NOT de IS NULL THEN {name:de.name,code:de.code,uri:dfcs.uri,date:dfcs.date,version:dfcs.version} ELSE NULL END AS edqmDoseForm}CALL {    WITH d    OPTIONAL MATCH (d)-[:CONTAINS]->(i:MmiIngredient)-[:IS_SUBSTANCE]->(s:Substance)     OPTIONAL MATCH (rx:RXCUI)-[:REFERENCES]->(s)     OPTIONAL MATCH (i)-[:CORRESPONDS_TO]->(ci:Ingredient)-[:IS_SUBSTANCE]->(cis:Substance)     OPTIONAL MATCH (ci)-[:HAS_UNIT]->(ciu:Unit)     OPTIONAL MATCH (i)-[:HAS_UNIT]->(iu:Unit)     WITH i, s, iu, collect(DISTINCT rx.code) AS rxCodes,     collect(CASE WHEN ci IS NOT NULL THEN {substanceMmiId:cis.mmiId,substanceName:cis.name,massFrom:ci.massFrom,massTo:ci.massTo,unit:ciu} ELSE null END) AS corresponding     RETURN collect(CASE WHEN s IS NOT NULL THEN {substanceMmiId:s.mmiId,substanceName:s.name,isActive:i.isActive,massFrom:i.massFrom,massTo:i.massTo,unit:iu,rxcuiCodes:rxCodes,ci:corresponding} ELSE null END) AS ingredients}OPTIONAL MATCH (d)-[:MATCHES]->(a:ATC)-[:BELONGS_TO]->(acs:CodingSystem) OPTIONAL MATCH (d)-[:HAS_UNIT]->(du:Unit) WITH p, d, df, edqmDoseForm, ingredients, collect(CASE WHEN NOT a IS NULL THEN {description:a.description,code:a.code,uri:acs.uri,date:acs.date,version:acs.version} ELSE NULL END) AS atcCodes, du OPTIONAL MATCH (p)<-[:BELONGS_TO]-(pk:Package) OPTIONAL MATCH (pkcs:CodingSystem)<-[:BELONGS_TO]-(pkc:Code)-->(pk) WITH p, d, df, edqmDoseForm, ingredients, atcCodes, du, pk, collect(CASE WHEN NOT pkc IS NULL THEN {code:pkc.code,uri:pkcs.uri,date:pkcs.date,version:pkcs.version} ELSE NULL END) as packageCodes WITH p, d, df, edqmDoseForm, ingredients, atcCodes, du, collect({name:pk.name,amount:pk.amount,onMarketDate:pk.onMarketDate,codes:packageCodes}) as packages OPTIONAL MATCH (pcs:CodingSystem)<-[:BELONGS_TO]-(pc:Code)-->(p) OPTIONAL MATCH (c:Company)-[:MANUFACTURES]->(p) RETURN p.name AS productName,p.mmiId AS mmiId,c.mmiId AS companyMmiId,c.name AS companyName,collect(CASE WHEN NOT pc IS NULL THEN {code:pc.code,uri:pcs.uri,date:pcs.date,version:pcs.version} ELSE NULL END) AS productCodes, collect({ingredients:ingredients,atcCodes:atcCodes,mmiDoseForm:df.mmiName,edqmDoseForm:edqmDoseForm,amount:d.amount,unit:du}) AS drugs, packages AS packages

